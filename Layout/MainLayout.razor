@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@using global::Sponsorship.Models

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <div>
                @if (currentUser != null)
                {
                    <span>Welcome @currentUser.FirstName @currentUser.LastName</span>
                }
                else
                {
                    <span>Please sign in</span>
                }
            </div>

            @if (currentUser != null)
            {
                <button class="btn btn-outline-secondary btn-sm" @onclick="Logout">Logout</button>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private SignInResponseDto? currentUser;

    protected override void OnInitialized()
    {
        SessionStorage.Init(JSRuntime);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        currentUser = await SessionStorage.GetUser();

        StateHasChanged();

        if (currentUser == null && !IsLoginOrRegisterPage())
        {
            Navigation.NavigateTo("/login");
        }

        await JSRuntime.InvokeVoidAsync("console.log",
            "[SponsorshipWeb] Current User:",
            currentUser);
    }

    private bool IsLoginOrRegisterPage()
    {
        var path = Navigation.ToAbsoluteUri(Navigation.Uri)
            .AbsolutePath
            .TrimEnd('/')
            .ToLowerInvariant();

        return path == "/login" || path == "/register";
    }

    private async Task Logout()
    {
        await SessionStorage.Clear();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}