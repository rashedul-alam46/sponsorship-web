@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@using global::Sponsorship.Models

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <div>
                @if (!isLoading)
                {
                    if (currentUser != null)
                    {
                        <span>Welcome @currentUser.FirstName @currentUser.LastName</span>
                    }
                    else
                    {
                        <span>Please sign in</span>
                    }
                }
            </div>

            @if (!isLoading && currentUser != null)
            {
                <button class="btn btn-outline-secondary btn-sm" @onclick="Logout">
                    Logout
                </button>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private SignInResponseDto? currentUser;
    private bool isLoading = true;

    protected override void OnInitialized()
    {
        SessionStorage.Init(JSRuntime);

        AppStateNotifier.OnChange += RefreshUser;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadUser();
    }

    private async Task LoadUser()
    {
        isLoading = true;

        currentUser = await SessionStorage.GetUser();

        isLoading = false;
    }

    private async void RefreshUser()
    {
        currentUser = await SessionStorage.GetUser();
        isLoading = false;

        await InvokeAsync(StateHasChanged);
    }

    private bool IsLoginPage()
    {
        var path = Navigation.ToAbsoluteUri(Navigation.Uri)
            .AbsolutePath
            .TrimEnd('/')
            .ToLowerInvariant();

        return path == "/login" || path == "/register";
    }

    private async Task Logout()
    {
        await SessionStorage.Clear();
        currentUser = null;

        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        AppStateNotifier.OnChange -= RefreshUser;
    }
}