@page "/home"
@inject NavigationManager Navigation

@using Sponsorship
@using global::Sponsorship.Models

<PageTitle>Home</PageTitle>

<div class="home-container">
    <div class="home-header">
        <h1>Welcome to Sponsorship System</h1>
        <p>@welcomeMessage</p>
    </div>

    <div class="home-content">
        <div class="row mt-5">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Sponsorship Requests</h5>
                        <p class="card-text">View and manage sponsorship requests</p>
                        <a href="/sponsorship" class="btn btn-primary">View Requests</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Dashboard</h5>
                        <p class="card-text">View your dashboard and analytics</p>
                        <a href="/home" class="btn btn-primary">Go to Dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string welcomeMessage = "Welcome to the Sponsorship System";

    protected override void OnInitialized()
    {
        // No session logic here anymore
        // Layout handles authentication

        welcomeMessage = "Welcome to the Sponsorship System";
    }
}