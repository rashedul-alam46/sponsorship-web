@page "/sponsorshiptype/new"
@page "/sponsorshiptype/edit/{TypeCode}"

@using System.Net.Http.Json
@using global::Sponsorship.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Sponsorship Type</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>@(IsEditMode ? "Edit Sponsorship Type" : "Create Sponsorship Type")</h3>
    <button class="btn btn-secondary" @onclick="GoBack">Back</button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<form @onsubmit="HandleSubmit" novalidate>
    <div class="row g-3">

        <!-- Type Code -->
        <div class="col-md-6">
            <label class="form-label">Type Code</label>
            <input class="@GetCss("TypeCode")"
                   value="@model.TypeCode"
                   @oninput="OnTypeCodeChanged"
                   type="text"
                   disabled="@IsEditMode" />

            @if (HasError("TypeCode"))
            {
                <div class="invalid-feedback">@GetError("TypeCode")</div>
            }
        </div>

        <!-- Type Name -->
        <div class="col-md-6">
            <label class="form-label">Type Name</label>
            <input class="@GetCss("TypeName")"
                   @bind="model.TypeName"
                   @bind:event="oninput" />

            @if (HasError("TypeName"))
            {
                <div class="invalid-feedback">@GetError("TypeName")</div>
            }
        </div>

        <!-- Description -->
        <div class="col-12">
            <label class="form-label">Description</label>
            <textarea class="@GetCss("Description")"
                      rows="3"
                      @bind="model.Description"
                      @bind:event="oninput"></textarea>

            @if (HasError("Description"))
            {
                <div class="invalid-feedback">@GetError("Description")</div>
            }
        </div>

        <!-- Active -->
        <div class="col-md-6 form-check mt-4 ms-2">
            <input class="form-check-input"
                   type="checkbox"
                   @bind="model.IsActive" />
            <label class="form-check-label">
                Is Active
            </label>
        </div>

    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary me-2">
            @(IsEditMode ? "Update" : "Save")
        </button>

        <button type="button" class="btn btn-secondary" @onclick="GoBack">
            Cancel
        </button>
    </div>
</form>

@code {

    [Parameter]
    public string? TypeCode { get; set; }

    private bool IsEditMode => !string.IsNullOrWhiteSpace(TypeCode);

    private SponsorshipTypeCreate model = new()
    {
        TypeCode = string.Empty,
        TypeName = string.Empty,
        Description = string.Empty,
        IsActive = true
    };

    private string? errorMessage;
    private string? successMessage;

    private readonly Dictionary<string, string> fieldErrors = new();

    protected override async Task OnInitializedAsync()
    {
        if (IsEditMode)
        {
            await LoadForEdit(TypeCode!);
        }
    }

    private async Task LoadForEdit(string code)
    {
        try
        {
            var response = await Http.GetFromJsonAsync<SponsorshipTypeCreate>(
                $"/api/sponsorshiptypes/{code}"
            );

            if (response != null)
            {
                model = response;
            }
            else
            {
                errorMessage = "Sponsorship Type not found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void OnTypeCodeChanged(ChangeEventArgs e)
    {
        model.TypeCode = e.Value?.ToString()?.ToUpperInvariant() ?? string.Empty;

        if (fieldErrors.ContainsKey("TypeCode"))
        {
            fieldErrors.Remove("TypeCode");
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;
        successMessage = null;
        fieldErrors.Clear();

        if (!Validate())
        {
            errorMessage = "Please fix validation errors.";
            return;
        }

        try
        {
            HttpResponseMessage response;

            if (IsEditMode)
            {
                response = await Http.PutAsJsonAsync(
                    $"/api/sponsorshiptypes/{TypeCode}",
                    model
                );
            }
            else
            {
                response = await Http.PostAsJsonAsync(
                    "/api/sponsorshiptypes",
                    model
                );
            }

            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/sponsorshiptypes");
            }
            else
            {
                errorMessage = "Operation failed.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private bool Validate()
    {
        bool valid = true;

        if (string.IsNullOrWhiteSpace(model.TypeCode))
        {
            fieldErrors["TypeCode"] = "Type Code is required.";
            valid = false;
        }

        if (string.IsNullOrWhiteSpace(model.TypeName))
        {
            fieldErrors["TypeName"] = "Type Name is required.";
            valid = false;
        }

        return valid;
    }

    private string GetCss(string field)
    {
        return fieldErrors.ContainsKey(field)
            ? "form-control is-invalid"
            : "form-control";
    }

    private bool HasError(string field)
        => fieldErrors.ContainsKey(field);

    private string GetError(string field)
        => fieldErrors.TryGetValue(field, out var msg) ? msg : string.Empty;

    private void GoBack()
    {
        Navigation.NavigateTo("/sponsorshiptypes");
    }
}